<% layout('layouts/main') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>Events</h3>

  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createEventModal">
    + Create Event
  </button>
</div>

<div class="row">
  <% events.forEach(event => { %>
    <div class="col-md-4 mb-3">

      <div class="card shadow-sm">
        <div class="card-body">

          <h5 class="card-title"><%= event.title %></h5>

          <p class="text-muted mb-1">
            <i class="bx bx-map"></i> <%= event.venue %>
          </p>

          <p class="text-muted">
            <i class="bx bx-calendar"></i>
            <%= event.event_date ? new Date(event.event_date).toDateString() : '-' %>
          </p>

          <a href="/events/<%= event.id %>"
             class="btn btn-sm btn-primary w-100">
            Open Event
          </a>

        </div>
      </div>

    </div>
  <% }) %>
</div>

<!-- CREATE EVENT MODAL -->
<div class="modal fade" id="createEventModal">
  <div class="modal-dialog">
    <div class="modal-content">

      <form method="post" action="/events/create">

        <div class="modal-header">
          <h5>Create Event</h5>
        </div>

        <div class="modal-body">

          <input class="form-control mb-2" name="title" placeholder="Event Title">
          <input class="form-control mb-2" name="groom_name" placeholder="Groom Name">
          <input class="form-control mb-2" name="bride_name" placeholder="Bride Name">
          <input class="form-control mb-2" name="venue" placeholder="Venue">
          <input class="form-control mb-2" type="date" name="event_date">

        </div>

        <div class="modal-footer">
          <button class="btn btn-primary">Save</button>
        </div>

      </form>

    </div>
  </div>
</div>