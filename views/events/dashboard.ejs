<% layout('layouts/main', { event: event }) %>

<div class="mb-4">

  <h3><%= event.title %></h3>

  <p class="text-muted">
    <%= event.groom_name %> ❤ <%= event.bride_name %>
  </p>

  <p class="text-muted">
    <i class="bx bx-map"></i> <%= event.venue %>
  </p>

</div>

<div class="row">

  <div class="col-md-4">
    <div class="card p-3 shadow-sm">
      <h6>Total Guests</h6>
      <h3><%= stats.totalGuests %></h3>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 shadow-sm">
      <h6>Scanned Guests</h6>
      <h3><%= stats.scannedGuests %></h3>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 shadow-sm">
      <h6>Double Entry Guests</h6>
      <h3><%= stats.doubleGuests %></h3>
    </div>
  </div>

</div>

<hr>

<div class="d-flex gap-2 mt-3">

  <a href="/events/<%= event.id %>/guests"
     class="btn btn-primary">
    Manage Guests
  </a>

  <a href="/events/<%= event.id %>/guests/upload"
     class="btn btn-secondary">
    Upload CSV
  </a>

  <a href="/events/<%= event.id %>/scan"
     class="btn btn-success">
    Scan QR
  </a>

</div>