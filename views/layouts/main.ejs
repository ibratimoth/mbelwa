<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wedding Card Manager</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <script src="https://unpkg.com/html5-qrcode"></script>

  <style>
    body {
      padding-top: 70px;
    }
  </style>
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top shadow-sm">
    <div class="container">

      <a href="/" class="navbar-brand fw-bold">Wedding Manager</a>

      <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="nav">

        <% if (typeof event !=='undefined' && event) { %>
          <div class="ms-3 me-auto">
            <span class="badge bg-primary">
              <i class="bx bx-calendar"></i>
              <%= event.title %>
            </span>
          </div>
          <% } %>

            <div class="ms-auto d-flex gap-2">

              <% if (typeof event !=='undefined' && event) { %>

                <a href="/events/<%= event.id %>/guests" class="btn btn-outline-primary btn-sm">
                  Guests
                </a>

                <a href="/events/<%= event.id %>/guests/upload" class="btn btn-outline-secondary btn-sm">
                  Upload
                </a>

                <a href="/events/<%= event.id %>/scan" class="btn btn-outline-success btn-sm">
                  Scan
                </a>

                <% if (typeof event !=='undefined' && event) { %>
                  <a href="/" class="btn btn-warning btn-sm">
                    Dashboard
                  </a>
                  <% } %>

                    <% } else { %>

                      <span class="text-muted small">No event selected</span>

                      <% } %>

            </div>
      </div>
    </div>
  </nav>

  <div class="container">
    <%- body %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>