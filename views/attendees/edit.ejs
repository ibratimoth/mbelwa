<% layout('layouts/main', { event: event }) -%>

<h3>Edit Guest</h3>

<form method="post"
      action="/events/<%= event.id %>/guests/<%= guest.id %>/edit">

  <div class="mb-3">
    <label>Name</label>
    <input class="form-control" name="name" value="<%= guest.name %>">
  </div>

  <div class="mb-3">
    <label>Phone</label>
    <input class="form-control" name="phone" value="<%= guest.phone %>">
  </div>

  <div class="mb-3">
    <label>Type</label>
    <select class="form-select" name="type">
      <option value="single" <%= guest.type==='single'?'selected':'' %>>Single</option>
      <option value="double" <%= guest.type==='double'?'selected':'' %>>Double</option>
    </select>
  </div>

  <div class="mb-3">
    <label>Number of Scans</label>
    <input class="form-control" name="scans" value="<%= guest.scans %>">
  </div>

  <button class="btn btn-primary">Save</button>

</form>